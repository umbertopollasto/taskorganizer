<div class="my-3 mb-8 flex flex-col items-center bg-white rounded-lg border shadow-md md:flex-row md:max-w-xl hover:bg-gray-100 dark:border-gray-700 dark:bg-gray-800 dark:hover:bg-gray-700">
  <%=image_tag "image-4.jpg" , class:"object-cover w-full h-64 rounded-t-lg md:h-36 md:w-24 md:rounded-none md:rounded-l-lg"%>
  <div class="flex flex-col justify-between p-4 leading-normal space-y-4">
    <h2 class="text-2xl font-bold text-indigo-500"> <%= @user.name%></h2>
    <div class="space-y-1">
      <h3 class="text-md font-semibold"><%= @user.email%></h3>

<%= @role.inspect%>
<div class="mx-auto w-full item-center grow overflow-x-auto relative">
  <table class="table-auto w-full text-sm text-left text-gray-500 dark:text-gray-400">
    <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
      <tr>
        <th scope="col" class="py-3 px-6">
          Name
        </th>
        <th scope="col" class="py-3 px-6">
          Started
        </th>
        <th scope="col" class="py-3 px-6">
          Worked hours 
        </th>
      </tr>
    </thead>
    <tbody>
    <div class="w-max rounded-xl bg-gray-100 px-3 py-2" >
    <%= @total_working_hours %>
    </div>
    <% if @user %>
      <% @all_projects.each do | project |%>
        <tr class="g-white border-b dark:bg-gray-800 dark:border-gray-700">
          <td class="px-3 py-2"><%= project['name'] %></td>
          <td class="px-3 py-2"><%= project['name'] %></td>
          <td class="px-3 py-2"><%= project['working_hours'] %></td>
        </tr> 
      <% end %>
    <% end %>
    </tbody>
  </table>
</div>




